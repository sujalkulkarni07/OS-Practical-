"FCFS"
#include <stdio.h>
// Function to calculate and display FCFS scheduling
void FCFS(int n, int bt[]) {
int wt[n], tat[n]; // Arrays to store waiting time and turnaround time
int total_wt = 0, total_tat = 0;
// The waiting time for the first process is always 0
wt[0] = 0;
// Calculate waiting time for each process
for (int i = 1; i < n; i++) {
wt[i] = wt[i - 1] + bt[i - 1];
}
// Calculate turnaround time for each process and accumulate totals
for (int i = 0; i < n; i++) {
tat[i] = wt[i] + bt[i];
total_wt += wt[i];
total_tat += tat[i];
}
// Print the scheduling results
printf("\nFCFS Scheduling:\n");
printf("Process\tBurst Time\tWaiting Time\tTurnaround Time\n");
for (int i = 0; i < n; i++) {
printf("P%d\t%d\t\t%d\t\t%d\n", i + 1, bt[i], wt[i], tat[i]);
}
// Print the averages
printf("\nAverage Waiting Time: %.2f", (float)total_wt / n);
printf("\nAverage Turnaround Time: %.2f\n", (float)total_tat / n);
}
int main() {
int n;
// Input number of processes
printf("Enter the number of processes: ");
scanf("%d", &n);
// Array to store burst times for each process
int bt[n];
// Input burst times for each process
for (int i = 0; i < n; i++) {
printf("Enter burst time for process P%d: ", i + 1);
scanf("%d", &bt[i]);
}
// Call FCFS function to perform the scheduling
FCFS(n, bt);
return 0;
}
















"Round Robin Algorithm."
#include <stdio.h>
// Function to perform Round Robin scheduling
void RoundRobin(int n, int bt[], int quantum) {
int rem_bt[n], wt[n], tat[n];
int total_wt = 0, total_tat = 0, time = 0;
// Initialize remaining burst times for all processes
for (int i = 0; i < n; i++) {
rem_bt[i] = bt[i];
}
// Perform Round Robin scheduling
while (1) {
int done = 1;
// Traverse each process to execute based on remaining burst time
for (int i = 0; i < n; i++) {
if (rem_bt[i] > 0) {
done = 0; // A process is still incomplete
if (rem_bt[i] > quantum) {
time += quantum; // Process executes for the quantum time
rem_bt[i] -= quantum;
} else {
time += rem_bt[i]; // Process completes in this cycle
wt[i] = time - bt[i]; // Waiting time is time elapsed minus burst time
rem_bt[i] = 0; // Process has finished
}
}
}
// Break out of the loop if all processes are completed
if (done == 1) break;
// Calculate Turnaround Time (TAT) for all processes
for (int i = 0; i < n; i++) {
tat[i] = bt[i] + wt[i]; // Turnaround time is burst time + waiting time
total_wt += wt[i];
total_tat += tat[i];
}
// Display the results of Round Robin Scheduling
printf("\nRound Robin Scheduling:\n");
printf("Process\tBurst Time\tWaiting Time\tTurnaround Time\n");
for (int i = 0; i < n; i++) {
printf("P%d\t%d\t\t%d\t\t%d\n", i + 1, bt[i], wt[i], tat[i]);
}
// Display the average waiting and turnaround times
printf("\nAverage Waiting Time: %.2f", (float)total_wt / n);
printf("\nAverage Turnaround Time: %.2f\n", (float)total_tat / n);
}
int main() {
int n, quantum;
// Input number of processes
printf("Enter the number of processes: ");
scanf("%d", &n);
// Array to store burst times for each process
int bt[n];
// Input burst time for each process
for (int i = 0; i < n; i++) {
printf("Enter burst time for process P%d: ", i + 1);
scanf("%d", &bt[i]);
}
// Input time quantum for Round Robin scheduling
printf("Enter time quantum: ");
scanf("%d", &quantum);
// Call Round Robin function to perform the scheduling
RoundRobin(n, bt, quantum);
return 0;
}


















