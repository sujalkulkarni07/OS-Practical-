#include <sys/types.h>
#include <stdio.h>
int main()
{
pid_t pid = fork(); // Create a child process
if (pid < 0)
{
// Fork failed
perror("Fork failed");
return 1;
}
if (pid == 0)
{
// This is the child process
printf("\nChild PID: %d\n", getpid());
printf("Parent PID: %d\n", getppid());
}
else
{
// This is the parent process
printf("\nParent PID: %d\n", getpid());
printf("Child PID: %d\n", pid);
}
return 0;
}
